# BizFinder QA Read API
# Real value lives only in the deploy host's ~/qa/.env (chmod 600) — never commit it.
QA_SHARED_SECRET=<your-qa-shared-secret>
QA_BASE_URL=https://bizfinder.ai
# QA_BASE_URL=https://staging.bizfinder.ai

# Target tenant for harness runs
QA_SITE_ID=qa-judge
# Pre-provisioning workaround:
# QA_SITE_ID=fftechsaas.xyz

# Preview URL (the page the harness drives in the browser).
# Two known patterns:
#   /?preview=<url-encoded host>          → floating "Talk to us" button
#   /preview?id=<tenant>                  → floating "Call us" button
QA_PREVIEW_URL=https://bizfinder.ai/preview?id=webwaala.com
# QA_PREVIEW_URL=https://bizfinder.ai/?preview=https%3A%2F%2Ffftechsaas.xyz

# OpenRouter (caller persona, scenario gen, text + audio judge)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_CALLER=deepseek/deepseek-chat
OPENROUTER_MODEL_SCENARIO=deepseek/deepseek-chat
OPENROUTER_MODEL_JUDGE_TEXT=anthropic/claude-haiku-4.5
OPENROUTER_MODEL_JUDGE_AUDIO=google/gemini-2.0-flash-001

# Caller TTS (Phase 1: cloud)
TTS_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
# ElevenLabs alternative
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Bot-side STT (we transcribe captured bot audio for live grading)
STT_PROVIDER=openai
OPENAI_STT_MODEL=whisper-1

# Dashboard auth gate (C8 — superseded by C9 per-user auth below; kept for the shim).
DASHBOARD_PASSWORD=

# Dashboard per-user auth (C9). JWT_SECRET = any long random string; if blank, an
# ephemeral key is used (tokens won't survive a restart — a banner warns). ADMIN_*
# seeds the first user on first run. Create more via scripts/manage_users.py.
JWT_SECRET=
JWT_ACCESS_MINUTES=720
ADMIN_EMAIL=
ADMIN_PASSWORD=
# QA_DB_URL=sqlite:///reports/qa.db   # default; override to point elsewhere

# Run config
QA_RATE_LIMIT_RPS=1
HARNESS_LOG_LEVEL=INFO
HARNESS_CONCURRENCY=2
HARNESS_RECORDINGS_DIR=recordings
HARNESS_REPORTS_DIR=reports

# Deploy controls (C11).
# HARNESS_RUNS_ENABLED: false = reporting-only (hides Run/Re-run pages). Phase A on
#   the analytics VPS keeps this false until ops installs Chromium system libs (root);
#   flip to true for Phase B (full runner).
HARNESS_RUNS_ENABLED=true
# HARNESS_HEADLESS: 1 forces --headless for dashboard-launched runs (set on headless hosts).
HARNESS_HEADLESS=
